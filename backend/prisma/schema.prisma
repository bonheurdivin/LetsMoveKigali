generator client {
  provider = "prisma-client-js"
}
// (unchanged - reposting for visibility, this is the same schema as before)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum TripStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BusStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

model User {
  id          String   @id @default(uuid())
  fullName    String
  email       String   @unique
  phone       String?
  password    String
  role        Role     @default(PASSENGER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Driver-specific (nullable for non-drivers)
  licenseNumber String?
  assignedBus   Bus?     @relation(fields: [busId], references: [id])
  busId         String?

  favorites     FavoriteRoute[]
  trips         Trip[]          @relation("DriverTrips")
  notifications Notification[]
}

model Bus {
  id          String    @id @default(uuid())
  busNumber   String    @unique
  plateNumber String
  fuelType    String    @default("Diesel")
  status      BusStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())

  drivers     User[]
  route       Route?    @relation(fields: [routeId], references: [id])
  routeId     String?
  trips       Trip[]
}

model Route {
  id          String   @id @default(uuid())
  name        String
  startPoint  String
  endPoint    String
  createdAt   DateTime @default(now())

  stops       Stop[]
  buses       Bus[]
  trips       Trip[]
  favorites   FavoriteRoute[]
}

model Stop {
  id         String   @id @default(uuid())
  name       String
  latitude   Float
  longitude  Float
  order      Int
  route      Route    @relation(fields: [routeId], references: [id])
  routeId    String
}

model Trip {
  id          String     @id @default(uuid())
  status      TripStatus @default(SCHEDULED)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime   @default(now())

  route       Route      @relation(fields: [routeId], references: [id])
  routeId     String
  bus         Bus        @relation(fields: [busId], references: [id])
  busId       String
  driver      User       @relation("DriverTrips", fields: [driverId], references: [id])
  driverId    String

  gpsLogs     GPSLocation[]
}

model GPSLocation {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  speed     Float?
  timestamp DateTime @default(now())

  trip      Trip     @relation(fields: [tripId], references: [id])
  tripId    String
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info") // e.g. delay, arrival, service_update
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model FavoriteRoute {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  route     Route    @relation(fields: [routeId], references: [id])
  routeId   String
  createdAt DateTime @default(now())

  @@unique([userId, routeId])
}